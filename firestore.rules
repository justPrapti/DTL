// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId} (matches request.auth.uid)
// Fields:
//   - uid: string (required) - The unique ID of the user.
//   - displayName: string (required) - The name of the user.
//   - photoURL: string (optional) - The profile picture URL.
//   - location: map (optional) - { latitude: number, longitude: number }
//   - isLocationOn: boolean (required) - Whether live location is active.
//   - lastSeen: timestamp (optional) - The last update time.
//
// Collection: vibeChecks
// Document ID: {vibeCheckId} (auto-generated)
// Fields:
//   - from: string (required) - The UID of the sender.
//   - fromName: string (required) - The name of the sender.
//   - to: string (required) - The UID of the recipient.
//   - timestamp: timestamp (required) - The time the vibe check was sent.
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'isLocationOn']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.isLocationOn is bool &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500)) &&
             (!('location' in data) || (data.location is map && data.location.latitude is number && data.location.longitude is number)) &&
             (!('lastSeen' in data) || (data.lastSeen is timestamp));
    }

    function isValidVibeCheck(data) {
      return data.keys().hasAll(['from', 'fromName', 'to', 'timestamp']) &&
             data.from is string && data.from == request.auth.uid &&
             data.fromName is string && data.fromName.size() > 0 && data.fromName.size() < 100 &&
             data.to is string && data.to.size() > 0 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Allow reading if authenticated and location is on, or if it's the owner
      // Use get() for individual docs and resource for queries
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        (resource != null && resource.data.isLocationOn == true)
      );
      
      // Allow creating own profile
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      // Allow updating own profile
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid;

      // Rules for savedLists subcollection
      match /savedLists/{listId} {
        allow read, write: if isOwner(userId);
      }

      // Rules for labeledPlaces subcollection
      match /labeledPlaces/{placeId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /vibeChecks/{vibeCheckId} {
      // Allow reading if the user is the recipient
      allow read: if isAuthenticated() && request.auth.uid == resource.data.to;
      
      // Allow creating if authenticated and sender is the user
      allow create: if isAuthenticated() && isValidVibeCheck(request.resource.data);
    }
  }
}
